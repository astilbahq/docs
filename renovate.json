{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":pinDevDependencies",
    "group:monorepos",
    "schedule:weekly"
  ],
  "timezone": "Europe/London",
  "rangeStrategy": "pin",
  "minimumReleaseAge": "3 days",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Manage the Node engine floor by hand; exact dependency pins must not turn it into a single patch release.",
      "matchDepTypes": ["engines"],
      "enabled": false
    },
    {
      "description": "Keep Astro and Starlight changes together for one documentation-shell review.",
      "groupName": "Astro and Starlight",
      "matchPackageNames": ["astro", "@astrojs/**", "starlight-*"]
    },
    {
      "description": "Keep Panda packages on one versioned toolchain.",
      "groupName": "Panda CSS",
      "matchPackageNames": ["@pandacss/**"]
    },
    {
      "description": "Review browser and static-analysis tooling together.",
      "groupName": "verification tooling",
      "matchPackageNames": [
        "@axe-core/playwright",
        "@playwright/test",
        "knip",
        "vitest"
      ]
    },
    {
      "description": "Auto-merge non-major development-tool updates after verification succeeds.",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Never auto-merge a major update.",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Auto-merge non-major GitHub Actions pin updates after verification succeeds.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"],
      "automerge": true
    }
  ]
}
