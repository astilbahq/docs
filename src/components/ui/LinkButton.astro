---
import type { HTMLAttributes } from "astro/types";
import { ghostControl } from "../../styles/recipes";

interface Props extends Omit<HTMLAttributes<"a">, "class"> {
  appearance?: "ghost" | "outline" | "primary";
  class?: string;
  iconOnly?: boolean;
  size?: "default" | "large";
}

const {
  appearance = "ghost",
  class: className,
  iconOnly = false,
  size = "default",
  ...attributes
} = Astro.props;
---

<a
  {...attributes}
  class:list={[ghostControl({ appearance, iconOnly, size }), className]}
>
  <slot />
</a>
