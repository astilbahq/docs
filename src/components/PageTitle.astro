---
import { css } from "../../styled-system/css";

const { title, description } = Astro.locals.starlightRoute.entry.data;

const titleClass = css({
  margin: 0,
  color: "ink.strong",
  fontSize: "var(--sl-text-h1)",
  fontWeight: "semibold",
  letterSpacing: "-0.02em",
  lineHeight: 1.5,
  textWrap: "balance",
});

const descriptionClass = css({
  maxInlineSize: "68ch",
  marginBlockStart: "0.25rem",
  color: "ink.muted",
  fontSize: "1.125rem",
  lineHeight: 1.55,
  textWrap: "pretty",
});
---

<h1 class={titleClass} id="_top">{title}</h1>
{description && <p class={descriptionClass}>{description}</p>}
