---
import StarlightHead from "@astrojs/starlight/components/Head.astro";

const { entry } = Astro.locals.starlightRoute;
const isDocumentationPage =
  entry.id !== "404" && !entry.id.endsWith("/404");
const baseUrl = Astro.site ?? Astro.url;
const markdownUrl = isDocumentationPage
  ? new URL(entry.id ? `/${entry.id}.md` : "/index.md", baseUrl)
  : undefined;
const llmsUrl = isDocumentationPage && Astro.site
  ? new URL("/llms.txt", Astro.site)
  : undefined;
---

<StarlightHead />
{
  markdownUrl && (
    <link
      href={markdownUrl}
      rel="alternate"
      title={`${entry.data.title} as Markdown`}
      type="text/markdown"
    />
  )
}
{
  llmsUrl && (
    <link href={llmsUrl} rel="describedby" type="text/plain" />
  )
}

<script>
  import "../scripts/register-webmcp";
</script>
