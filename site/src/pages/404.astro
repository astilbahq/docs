---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout description="The requested Astilba page does not exist." title="Page not found — Astilba">
  <section class="not-found section-shell">
    <p class="eyebrow">404 · No route</p>
    <h1>This path has no guarantee.</h1>
    <p>The page may have moved, or it may never have existed.</p>
    <div class="action-row">
      <a class="action action--primary" href="/">Return home</a>
      <a class="action action--secondary" href="/docs/">Open documentation</a>
    </div>
  </section>
</SiteLayout>
