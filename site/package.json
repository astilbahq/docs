{
  "name": "@astilba/site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build && node scripts/verify-built-site.mjs",
    "build:production": "cross-env ASTILBA_SITE=https://astilba.com pnpm build",
    "check": "astro check && tsc --noEmit",
    "deploy": "pnpm build:production && wrangler deploy",
    "deploy:dry-run": "pnpm build:production && wrangler deploy --dry-run",
    "dev": "astro dev",
    "preview": "astro preview",
    "smoke:production": "node scripts/smoke-production.mjs",
    "test": "vitest run",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "astro": "7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "cross-env": "10.1.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
