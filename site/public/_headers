/*
  Content-Security-Policy: default-src 'none'; base-uri 'none'; connect-src 'self'; font-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; manifest-src 'self'; script-src 'self'; style-src 'self'; object-src 'none'; upgrade-insecure-requests
  Content-Signal: ai-train=yes, search=yes, ai-input=yes
  Permissions-Policy: accelerometer=(), ambient-light-sensor=(), autoplay=(), bluetooth=(), camera=(), clipboard-read=(), clipboard-write=(), display-capture=(), encrypted-media=(), fullscreen=(self), gamepad=(), geolocation=(), gyroscope=(), hid=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-create=(), publickey-credentials-get=(), screen-wake-lock=(), serial=(), usb=(), web-share=(), xr-spatial-tracking=()
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/site.js
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

/sitemap*.xml
  Cache-Control: public, max-age=3600

/llms.txt
  Cache-Control: public, max-age=3600

/.well-known/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff

/.well-known/agent-skills/index.json
  Content-Type: application/json; charset=utf-8

/.well-known/api-catalog
  Content-Type: application/linkset+json; profile="https://www.rfc-editor.org/info/rfc9727"
  Link: </.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json"

/.well-known/mcp/*
  Content-Type: application/json; charset=utf-8

/mcp/server-card
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600
  Content-Type: application/mcp-server-card+json
  X-Content-Type-Options: nosniff
